PORT=5000
NODE_ENV=development
JWT_SECRET=change_this_secret
MAX_UPLOAD_SIZE_MB=25
OCR_REVIEW_WINDOW_DAYS=14
FILE_RETENTION_DAYS=14
PDF_OCR_ENGINE=auto
PDF_TEXT_THRESHOLD=200
PDF_IMPORT_RETENTION_DAYS=14
PDF_IMPORT_CONCURRENCY=1

# PostgreSQL — elige uno de los formatos según tu proveedor:
# Neon:     postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/siepa?sslmode=require
# Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@host:5432/siepa?schema=public"

# DeepSeek AI — explicaciones pedagógicas para estudiantes
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Python OCR microservice (ocr-service/). Leave at default if running locally.
OCR_SERVICE_URL=http://localhost:8001
