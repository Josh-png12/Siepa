# ==========================================
# SIEPA Backend - Environment Variables
# ==========================================
# Copy this file to .env and fill in the values
# Never commit .env to version control

# ==========================================
# REQUIRED - Application
# ==========================================
NODE_ENV=production

# Server port
PORT=5000

# JWT secret for authentication tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_change_me

# CORS allowed origins (comma-separated)
# Production: http://TU_IP_O_DOMINIO,https://TU_DOMINIO
# Development: http://localhost:5173,http://localhost:3000
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ==========================================
# REQUIRED - Database (PostgreSQL)
# ==========================================
# Local PostgreSQL: postgresql://user:password@localhost:5432/siepa
# Remote PostgreSQL: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/siepa

# ==========================================
# AI / OCR Services (Optional)
# ==========================================

# Replicate API token (DeepSeek-VL vision model)
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# DeepSeek AI API key (for pedagogical explanations)
# Get from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# Replicate model (optional, defaults to deepseek-ai/deepseek-vl-7b-base)
# REPLICATE_DEEPSEEK_VL_MODEL=deepseek-ai/deepseek-vl-7b-base

# OCR microservice URL (only needed if running separate OCR service)
# OCR_SERVICE_URL=http://localhost:8001
